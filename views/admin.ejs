<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-8">
    <h1 class="text-2xl font-bold mb-6">Admin Panel</h1>
    
    <!-- Profile Photo Upload Section -->
    <div class="bg-white p-6 rounded-lg shadow mb-6">
        <h2 class="text-lg font-bold mb-4">Profile Photo</h2>
        <% if (data.profilePhoto) { %>
            <div class="mb-4">
                <img src="<%= data.profilePhoto %>" alt="Profile" class="h-32 w-32 rounded-lg object-cover border-2 border-gray-300">
            </div>
        <% } %>
        <form action="/upload-photo" method="POST" enctype="multipart/form-data" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700">Upload New Photo</label>
                <input type="file" name="profile_photo" accept="image/*" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm" required>
                <p class="text-xs text-gray-500 mt-1">Max size: 5MB (JPG, PNG, GIF)</p>
            </div>
            <button type="submit" class="bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600">Upload Photo</button>
        </form>
    </div>

    <form action="/update" method="POST" class="space-y-6">
        <div>
            <label class="block text-sm font-medium text-gray-700">Name</label>
            <input type="text" name="name" value="<%= data.name %>" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm">
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700">Title</label>
            <input type="text" name="title" value="<%= data.title %>" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm">
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700">Description</label>
            <textarea name="description" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm"><%= data.description %></textarea>
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700">About (Paragraphs)</label>
            <% data.about.forEach((para, index) => { %>
                <textarea name="about[<%= index %>]" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm"><%= para %></textarea>
            <% }) %>
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700">Footer</label>
            <input type="text" name="footer" value="<%= data.footer %>" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm">
        </div>
        <button type="submit" class="bg-blue-500 text-white px-4 py-2 rounded">Update</button>
    </form>
    <a href="/" class="mt-4 inline-block text-blue-500">View Portfolio</a>
</body>
</html>