<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= name %> | <%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        navy: '#0a192f',
                        gold: '#F7C948',
                        slate: {
                            400: '#94a3b8',
                            200: '#e2e8f0',
                        }
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-navy leading-relaxed text-slate-400 antialiased selection:bg-gold/30 selection:text-gold">

    <div id="glow" class="pointer-events-none fixed inset-0 z-30 transition duration-300"></div>

    <!-- Desktop Top Navbar -->
    <nav class="hidden lg:block fixed top-0 left-0 right-0 z-50 bg-navy/90 backdrop-blur-sm border-b border-slate-200/10">
        <div class="mx-auto max-w-screen-xl px-6 py-4">
            <div class="flex items-center justify-between">
                <h1 class="text-lg font-bold text-slate-200"><%= name %></h1>
                <ul class="flex space-x-8">
                    <li><a href="#about" class="text-slate-400 hover:text-slate-200 transition">About</a></li>
                    <li><a href="#experience" class="text-slate-400 hover:text-slate-200 transition">Experience</a></li>
                    <li><a href="#projects" class="text-slate-400 hover:text-slate-200 transition">Projects</a></li>
                    <li><a href="#contact" class="text-slate-400 hover:text-slate-200 transition">Contact</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Mobile Navbar -->
    <nav class="lg:hidden fixed top-0 left-0 right-0 z-50 bg-navy/90 backdrop-blur-sm border-b border-slate-200/10">
        <div class="flex items-center justify-between px-6 py-4">
            <h1 class="text-lg font-bold text-slate-200"><%= name %></h1>
            <button id="menu-toggle" class="text-slate-400 hover:text-slate-200">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>
        <div id="mobile-menu" class="hidden px-6 pb-4">
            <ul class="space-y-2">
                <li><a href="#about" class="block py-2 text-slate-400 hover:text-slate-200">About</a></li>
                <li><a href="#experience" class="block py-2 text-slate-400 hover:text-slate-200">Experience</a></li>
                <li><a href="#projects" class="block py-2 text-slate-400 hover:text-slate-200">Projects</a></li>
                <li><a href="#contact" class="block py-2 text-slate-400 hover:text-slate-200">Contact</a></li>
            </ul>
        </div>
    </nav>

    <div class="mx-auto min-h-screen px-6 py-12 font-sans md:px-12 md:py-20 lg:px-24 lg:py-0 lg:pt-20">
        <div class="lg:flex lg:justify-between lg:gap-4 lg:max-w-screen-xl lg:mx-auto">
            
            <header class="lg:sticky lg:top-0 lg:flex lg:max-h-screen lg:w-1/2 lg:flex-col lg:justify-between lg:py-24">
                <div>
                    <h1 class="text-4xl font-bold tracking-tight text-slate-200 sm:text-5xl">
                        <a href="#"><%= name %></a>
                    </h1>
                    <h2 class="mt-3 text-lg font-medium tracking-tight text-slate-200 sm:text-xl">
                        <%= title %>
                    </h2>
                    <p class="mt-4 max-w-xs leading-normal">
                        <%= description %>
                    </p>
                    <div class="mt-8 h-32 w-32 overflow-hidden rounded-xl border-2 border-slate-200/10 bg-slate-200/5 transition-colors hover:border-gold/50">
                        <div class="flex h-full items-center justify-center text-[10px] uppercase tracking-widest text-slate-500">
                            Photo Space
                        </div>
                    </div>

                    <nav class="nav hidden lg:block mt-16">
                        <ul class="w-max">
                            <li>
                                <a class="group flex items-center py-3" href="#about">
                                    <span class="mr-4 h-px w-8 bg-slate-600 transition-all group-hover:w-16 group-hover:bg-slate-200"></span>
                                    <span class="text-xs font-bold uppercase tracking-widest text-slate-500 group-hover:text-slate-200">About</span>
                                </a>
                            </li>
                            <li>
                                <a class="group flex items-center py-3" href="#experience">
                                    <span class="mr-4 h-px w-8 bg-slate-600 transition-all group-hover:w-16 group-hover:bg-slate-200"></span>
                                    <span class="text-xs font-bold uppercase tracking-widest text-slate-500 group-hover:text-slate-200">Experience</span>
                                </a>
                            </li>
                            <li>
                                <a class="group flex items-center py-3" href="#projects">
                                    <span class="mr-4 h-px w-8 bg-slate-600 transition-all group-hover:w-16 group-hover:bg-slate-200"></span>
                                    <span class="text-xs font-bold uppercase tracking-widest text-slate-500 group-hover:text-slate-200">Projects</span>
                                </a>
                            </li>
                            <li>
                                <a class="group flex items-center py-3" href="#contact">
                                    <span class="mr-4 h-px w-8 bg-slate-600 transition-all group-hover:w-16 group-hover:bg-slate-200"></span>
                                    <span class="text-xs font-bold uppercase tracking-widest text-slate-500 group-hover:text-slate-200">Contact</span>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>

                <div class="mt-8 flex items-center gap-5 text-slate-400">
                    <a href="#" class="hover:text-slate-200">GitHub</a>
                    <a href="#" class="hover:text-slate-200">LinkedIn</a>
                    <a href="mailto:noahaizeboje@gmail.com" class="hover:text-slate-200">Email</a>
                    <a href="https://wa.me/2347042340069" target="_blank" class="hover:text-slate-200">WhatsApp 1</a>
                    <a href="https://wa.me/2348161689347" target="_blank" class="hover:text-slate-200">WhatsApp 2</a>
                </div>
            </header>

            <main class="pt-24 lg:w-1/2 lg:py-24">
                
                <section id="about" class="mb-16 scroll-mt-16 md:mb-24 lg:mb-36">
                    <h3 class="text-sm font-bold uppercase tracking-widest text-slate-200 lg:hidden mb-4">About</h3>
                    <% about.forEach(paragraph => { %>
                        <p class="mb-4"><%= paragraph %></p>
                    <% }) %>
                </section>

                <section id="experience" class="mb-16 scroll-mt-16">
                    <h3 class="text-sm font-bold uppercase tracking-widest text-slate-200 mb-8">Experience</h3>
                    
                    <% experiences.forEach(exp => { %>
                    <div class="group relative mb-12 grid grid-cols-1 gap-4 transition-all sm:grid-cols-8 lg:hover:!opacity-100 lg:group-hover/list:opacity-50">
                        <div class="absolute -inset-x-4 -inset-y-4 z-0 hidden rounded-md transition lg:-inset-x-6 lg:block lg:group-hover:bg-slate-800/50"></div>
                        <header class="z-10 text-xs font-semibold uppercase tracking-wide text-slate-500 sm:col-span-2"><%= exp.period %></header>
                        <div class="z-10 sm:col-span-6">
                            <h3 class="font-medium leading-snug text-slate-200"><%= exp.position %></h3>
                            <p class="mt-2 text-sm leading-normal"><%= exp.description %></p>
                        </div>
                    </div>
                    <% }) %>
                </section>

                <section id="projects" class="mb-16 scroll-mt-16">
                    <h3 class="text-sm font-bold uppercase tracking-widest text-slate-200 mb-8">Selected Projects</h3>
                    <% projects.forEach(project => { %>
                    <div class="group relative mb-12 grid grid-cols-1 gap-4 transition-all sm:grid-cols-8 lg:hover:!opacity-100 lg:group-hover/list:opacity-50">
                        <div class="absolute -inset-x-4 -inset-y-4 z-0 hidden rounded-md transition lg:-inset-x-6 lg:block lg:group-hover:bg-slate-800/50"></div>
                        <header class="z-10 text-xs font-semibold uppercase tracking-wide text-slate-500 sm:col-span-2"><%= project.title %></header>
                        <div class="z-10 sm:col-span-6">
                            <p class="mt-2 text-sm leading-normal"><%= project.description %></p>
                        </div>
                    </div>
                    <% }) %>
                </section>

                <section id="contact" class="mb-16 scroll-mt-16">
                    <h3 class="text-sm font-bold uppercase tracking-widest text-slate-200 mb-8">Contact</h3>
                    <p class="mb-4">I'm always open to discussing new opportunities, collaborations, or just having a chat about technology. Feel free to reach out!</p>
                    <div class="flex flex-col gap-4">
                        <a href="mailto:noahaizeboje@gmail.com" class="text-gold hover:underline">📧 noahaizeboje@gmail.com</a>
                        <a href="https://wa.me/2347042340069" target="_blank" class="text-gold hover:underline">📱 WhatsApp: +234 704 234 0069</a>
                        <a href="https://wa.me/2348161689347" target="_blank" class="text-gold hover:underline">📱 WhatsApp: +234 816 168 9347</a>
                    </div>
                </section>

                <footer class="max-w-md pb-16 text-xs text-slate-500 sm:pb-0">
                    <p><%= footer %></p>
                </footer>
            </main>
        </div>
    </div>

    <script src="/js/main.js"></script>
</body>
</html>